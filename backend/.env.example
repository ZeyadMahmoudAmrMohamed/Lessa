# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project URL from Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co

# service_role key (never expose to frontend) — Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT secret — Settings → API → JWT Settings → JWT Secret
# Used to verify tokens issued by Supabase Auth
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# ─── Branch ───────────────────────────────────────────────────────────────────
# UUID of the single MVP branch row — seed this in your DB first
BRANCH_ID=00000000-0000-0000-0000-000000000001
